# Gemini
GEMINI_API_KEY=
GEMINI_MODEL_PRO=gemini-2.5-pro
GEMINI_MODEL_FLASH=gemini-2.5-flash
GEMINI_MODEL_LIVE=gemini-2.5-flash-live

# Google Cloud
GCP_PROJECT_ID=
GCP_REGION=europe-west1
GCP_VERTEX_INDEX_ID=
FIRESTORE_DATABASE=(default)

# OAuth (Google Calendar)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Voice — Gemini Live (in-browser) + Cloud TTS fallback. NO Twilio, NO third-party telephony.
# The "agent calls Mom in Turkish" moment happens inside the demo browser via a simulated
# phone-call UI binding to a Gemini Live audio stream. Pure Google stack.

# Demo recipient labels (shown in the simulated phone UI — not dialed)
DEMO_AHMET_PHONE=+90 ___
DEMO_AYLIN_PHONE=+90 ___
DEMO_SELIN_PHONE=+90 ___

# Runtime
PORT=8080
LOG_LEVEL=INFO
