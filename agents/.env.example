# Gemini
GEMINI_API_KEY=
GEMINI_MODEL_PRO=gemini-2.5-pro
GEMINI_MODEL_FLASH=gemini-2.5-flash
GEMINI_MODEL_LIVE=gemini-2.5-flash-live

# Google Cloud
GCP_PROJECT_ID=
GCP_REGION=europe-west1
GCP_VERTEX_INDEX_ID=
FIRESTORE_DATABASE=(default)

# OAuth (Google Calendar)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Twilio (outbound voice calls — the "agent calls Mom in Turkish" demo)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Demo phone numbers (the personas — for demo only, override per env)
DEMO_AHMET_PHONE=+90...
DEMO_AYLIN_PHONE=+90...
DEMO_SELIN_PHONE=+90...

# Runtime
PORT=8080
LOG_LEVEL=INFO
